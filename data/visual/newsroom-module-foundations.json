{
  "version": "1.0",
  "purpose": "Phase 70 foundations manifest: contracts for future newsroom visual modules. Schema only — no rendering implemented. Each module declares its data dependencies and owning editorial vertical so the visual layer can be built without re-architecting the intelligence layer.",
  "modules": [
    {
      "id": "analyst-card",
      "title": "Analyst Desk Card",
      "vertical": "any",
      "status": "foundation",
      "data_sources": [
        "tools/editorial-personas.js#VERTICALS[*].visual",
        "data/intelligence/publishing-report.json"
      ],
      "contract": {
        "persona": "string",
        "accent": "css-color",
        "icon": "string",
        "latest_slug": "string",
        "stance": "directional_bias"
      }
    },
    {
      "id": "macro-dashboard-strip",
      "title": "Macro Regime Dashboard Strip",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/market-narrative-state.json#regimes"
      ],
      "contract": {
        "regimes": "object<regime,string>",
        "updated_at": "iso-datetime",
        "continuity_note": "string"
      }
    },
    {
      "id": "asset-heatmap",
      "title": "Cross-Asset Heatmap",
      "vertical": "market-outlook",
      "status": "foundation",
      "data_sources": [
        "data/live-market-state.json",
        "tools/analyst-voice-engine.js#ASSET_CAUSAL_MAP"
      ],
      "contract": {
        "assets": "array<{symbol,change_pct,regime_color}>",
        "causal_highlights": "array<string>"
      }
    },
    {
      "id": "market-pulse-widget",
      "title": "Market Pulse Widget",
      "vertical": "newswire",
      "status": "foundation",
      "data_sources": [
        "data/live-market-state.json#vix",
        "data/economic-calendar.json"
      ],
      "contract": {
        "volatility_state": "string",
        "next_event": "string",
        "next_event_time": "iso-datetime"
      }
    },
    {
      "id": "institutional-signal-overlay",
      "title": "Institutional Signal Overlay",
      "vertical": "signals",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/market-narrative-state.json#dominant_themes"
      ],
      "contract": {
        "themes": "array<{theme,status}>",
        "risk_disclosure": "string (mandatory)"
      }
    },
    {
      "id": "newsroom-homepage-module",
      "title": "Newsroom Homepage Module",
      "vertical": "any",
      "status": "foundation",
      "data_sources": [
        "data/feeds/homepage-featured.json",
        "tools/editorial-personas.js#VERTICALS"
      ],
      "contract": {
        "sections": "array<{vertical,label,articles:array<{slug,title,locale}>}>"
      }
    },
    {
      "id": "volatility-surface",
      "title": "Volatility Surface View",
      "vertical": "market-outlook",
      "status": "foundation",
      "data_sources": [
        "data/live-market-state.json#vix",
        "data/intelligence/market-pulse.json#dimensions.volatility_regime"
      ],
      "contract": {
        "regime": "string",
        "vix_level": "number|null",
        "history": "array<{date,level}>"
      }
    },
    {
      "id": "liquidity-map",
      "title": "Liquidity Migration Map",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/market-pulse.json#dimensions.liquidity_stress",
        "data/intelligence/market-narrative-state.json#regimes"
      ],
      "contract": {
        "liquidity_state": "string",
        "flows": "array<{from,to,evidence}>"
      }
    },
    {
      "id": "sector-leadership-board",
      "title": "Sector Leadership Board",
      "vertical": "market-outlook",
      "status": "foundation",
      "data_sources": [
        "data/live-market-state.json#sector_etfs"
      ],
      "contract": {
        "leaders": "array<{symbol,change_pct}>",
        "laggards": "array<{symbol,change_pct}>"
      }
    },
    {
      "id": "market-matrix",
      "title": "Cross-Asset Market Matrix",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "tools/analyst-voice-engine.js#ASSET_CAUSAL_MAP",
        "data/live-market-state.json"
      ],
      "contract": {
        "rows": "array<{pair,state,chain}>"
      }
    },
    {
      "id": "desk-alerts",
      "title": "Desk Alerts",
      "vertical": "newswire",
      "status": "live",
      "data_sources": [
        "data/intelligence/market-cognition.json#alerts"
      ],
      "contract": {
        "alerts": "array<{type,severity,headline_en,headline_ar,derived_from}>"
      }
    },
    {
      "id": "market-memory",
      "title": "Market Memory",
      "vertical": "macro-desk",
      "status": "live",
      "data_sources": [
        "data/intelligence/market-cognition.json#memory_observations",
        "data/intelligence/session-history.json"
      ],
      "contract": {
        "observations": "array<{kind,sessions,en,ar}>"
      }
    },
    {
      "id": "market-state-evolution",
      "title": "Market State Evolution",
      "vertical": "macro-desk",
      "status": "live",
      "data_sources": [
        "data/intelligence/market-timeline.json#events",
        "data/intelligence/market-cognition.json#timeline_tail"
      ],
      "contract": {
        "events": "array<{date,dimension,from,to}>"
      }
    },
    {
      "id": "causal-network",
      "title": "Cross-Asset Causal Network",
      "vertical": "macro-desk",
      "status": "live",
      "data_sources": [
        "data/intelligence/market-cognition.json#causal_links"
      ],
      "contract": {
        "links": "array<{id,legs,expected,state,evidence}>"
      }
    },
    {
      "id": "desk-conviction",
      "title": "Desk Conviction",
      "vertical": "macro-desk",
      "status": "live",
      "data_sources": [
        "data/intelligence/macro-cognition.json#conviction",
        "data/intelligence/macro-cognition.json#contradictions",
        "data/intelligence/macro-cognition.json#pressure"
      ],
      "contract": {
        "conviction": "{state,regime_confidence,confirmations,contradictions,en,ar}",
        "contradictions": "array<{id,sessions,escalated,en,ar}>",
        "pressure": "{tracks,elevated}"
      }
    },
    {
      "id": "scenario-monitor",
      "title": "Scenario Monitor",
      "vertical": "macro-desk",
      "status": "live",
      "data_sources": [
        "data/intelligence/macro-cognition.json#scenarios"
      ],
      "contract": {
        "scenarios": "array<{id,status,en,ar,derived_from,catalyst?}>"
      }
    },
    {
      "id": "pressure-map",
      "title": "Market Pressure Map",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/macro-cognition.json#pressure"
      ],
      "contract": {
        "tracks": "array<{track,score,state,history}>"
      }
    },
    {
      "id": "regime-transition-map",
      "title": "Regime Transition Map",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/market-timeline.json#events",
        "data/intelligence/market-cognition.json#regime_shifts"
      ],
      "contract": {
        "nodes": "array<{dimension,state,phase}>",
        "transitions": "array<{date,from,to}>"
      }
    },
    {
      "id": "macro-dependency-map",
      "title": "Macro Dependency Map",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/market-cognition.json#causal_links",
        "data/intelligence/macro-cognition.json#contradictions"
      ],
      "contract": {
        "edges": "array<{legs,expected,state,intensity}>"
      }
    },
    {
      "id": "concentration-map",
      "title": "Concentration Map",
      "vertical": "market-outlook",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/macro-cognition.json#pressure.tracks.concentration_pressure",
        "data/live-market-state.json#nvda"
      ],
      "contract": {
        "readings": "array<{metric,value,state}>"
      }
    },
    {
      "id": "premium-article-surface",
      "title": "Premium Article Surface",
      "vertical": "market-outlook",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/narrative-convergence.json",
        "data/intelligence/daily-intelligence-brief.json"
      ],
      "contract": {
        "lead": "{headline,kicker,regime_context}",
        "body_slots": "array<{type:paragraph|visual|pullquote,ref}>",
        "continuity_footer": "{prior_refs,unresolved}"
      }
    },
    {
      "id": "market-outlook-surface",
      "title": "Institutional Market Outlook Surface",
      "vertical": "market-outlook",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/macro-cognition.json#scenarios",
        "data/intelligence/narrative-convergence.json"
      ],
      "contract": {
        "scenario_rail": "array<{id,status}>",
        "coherence_strip": "{score,band}",
        "visual_slots": "array<{slot,kind}>"
      }
    },
    {
      "id": "chart-intelligence-slot",
      "title": "Chart Intelligence Slot",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "/api/live-quotes",
        "data/intelligence/market-timeline.json"
      ],
      "contract": {
        "slot": "{container_id,asset,overlay_kind:transition|pressure|divergence,annotations:array}",
        "renderer": "pluggable (TradingView-compatible)"
      }
    },
    {
      "id": "macro-visual-annotations",
      "title": "Macro Visual Annotations",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/market-cognition.json#timeline_tail",
        "data/intelligence/narrative-convergence.json#diverges"
      ],
      "contract": {
        "annotations": "array<{date,kind,label_en,label_ar,evidence}>"
      }
    },
    {
      "id": "editorial-graphics-adapter",
      "title": "Editorial Graphics Adapter",
      "vertical": "newswire",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/daily-intelligence-brief.json"
      ],
      "contract": {
        "card": "{headline,metric_rows,palette:institutional,locale}",
        "targets": [
          "article-inline",
          "telegram",
          "x",
          "instagram"
        ]
      }
    },
    {
      "id": "cross-surface-continuity",
      "title": "Cross-Surface Narrative Continuity",
      "vertical": "macro-desk",
      "status": "foundation",
      "data_sources": [
        "data/intelligence/narrative-convergence.json",
        "data/intelligence/market-narrative-state.json"
      ],
      "contract": {
        "thread": "{theme_id,surfaces:array<homepage|article|outlook|telegram>,last_state}"
      }
    }
  ]
}
