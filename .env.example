# Configuration Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Google Analytics 4 Measurement ID
GA4_ID=G-XXXXXXXXXX

# Email Configuration (for backend)
CONTACT_EMAIL=your-email@example.com

# Telegram Bot Token (if needed for notifications)
TELEGRAM_TOKEN=your-telegram-token

# API Keys (if using external services)
# STRIPE_KEY=sk_live_...
# SENDGRID_KEY=SG...

# =============================================================
# Market Portal Provider Configuration
# =============================================================
# Keep real keys out of frontend JavaScript. All market data
# must be served through protected Netlify Functions (serverless).
#
# To enable Finnhub live data (Phase 9 — implemented):
#   1. Get a free key at https://finnhub.io/register
#   2. Set FINNHUB_API_KEY=your-key in Netlify environment variables
#   3. Set MARKET_DATA_PROVIDER=finnhub in Netlify environment variables
#   4. Deploy — the serverless function handles the key securely
#
# Other providers (Alpha Vantage, Polygon, Yahoo) are stubbed and
# will be implemented in Phase 10+.
# =============================================================

# Active provider: mock | finnhub | alpha-vantage | polygon | yahoo
MARKET_DATA_PROVIDER=mock

# Finnhub (Phase 9 — live integration ready)
# Free tier: 60 API calls/minute. 2-3 calls per stock request.
# Server-side cache reduces repeat calls within 55 seconds.
FINNHUB_API_KEY=

# Alpha Vantage (Phase 10+ — stub only)
ALPHA_VANTAGE_API_KEY=

# Polygon.io (Phase 10+ — stub only)
POLYGON_API_KEY=

# OpenAI (future use)
OPENAI_API_KEY=

# Optional serverless/cache settings
MARKET_DATA_CACHE_SECONDS=60
MARKET_FUNDAMENTALS_CACHE_SECONDS=3600
