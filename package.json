    "market-regime:update": "node tools/update-market-regime.js",
    "market-state:update": "node tools/update-live-market-state.js",
    "market-state:check": "node tools/update-live-market-state.js --validate-only",
    "topic-memory:check": "node tools/check-topic-similarity.js",
    "links:intelligent": "node tools/generate-intelligent-links.js",
    "content:score": "node tools/score-generated-content.js",
    "check:ar-rtl": "node tools/check-ar-rtl.js",
    "publishing:status": "node tools/publishing-control-center.js",
    "publishing:brain": "node tools/autonomous-publishing-brain.js",
    "publishing:brain:status": "node tools/autonomous-publishing-brain.js --mode=status --content-type=all",
    "publishing:review": "node tools/autonomous-review-engine.js",
