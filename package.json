    "market-outlook:full-pipeline-dry": "node tools/run-full-market-outlook-pipeline.js --dry-run=true",
    "check:language-purity": "node tools/check-language-purity.js",
    "knowledge:build": "node tools/build-content-knowledge-graph.js --write",
    "knowledge:pairs": "node tools/build-article-pairs.js --write",
    "knowledge:clusters": "node tools/analyze-content-clusters.js --write",
    "knowledge:orphans": "node tools/detect-orphan-pages.js --write",
    "knowledge:gaps": "node tools/detect-content-gaps.js --write",
    "knowledge:topology": "node tools/analyze-seo-topology.js --write",
