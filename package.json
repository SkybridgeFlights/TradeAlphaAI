    "insights:generate": "node tools/generate-insights.js --queue --mode=review",
    "insights:controlled": "node tools/generate-controlled-insights.js",
    "insights:quality": "node tools/check-insight-quality.js",
    "insights:pipeline": "node tools/run-insight-pipeline.js --mode=review",
