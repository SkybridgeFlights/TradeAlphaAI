{
  "name": "tradealphaai-static-site",
  "version": "1.0.0",
  "private": true,
  "description": "Static TradeAlphaAI website tooling for generated market SEO pages.",
  "scripts": {
    "generate:market-pages": "node tools/generate-market-pages.js && node tools/generate-comparison-pages.js",
    "generate:comparisons": "node tools/generate-comparison-pages.js",
    "generate:seo-sitemaps": "node tools/generate-seo-sitemaps.js",
    "check:seo": "node tools/check-seo-structure.js",
    "check:market-pages": "node tools/check-market-pages.js",
    "check:utf8": "node tools/check-utf8-integrity.js",
    "check:production": "node tools/check-production-readiness.js",
    "insights:discover": "node tools/discover-insight-topics.js",
    "insights:generate": "node tools/generate-insights.js --queue --mode=review",
    "insights:controlled": "node tools/generate-controlled-insights.js",
    "insights:quality": "node tools/check-insight-quality.js",
    "insights:pipeline": "node tools/run-insight-pipeline.js --mode=review",
    "insights:publish-safe": "node tools/run-insight-pipeline.js --mode=publish-if-safe",
    "research-assets:generate": "node tools/generate-research-assets.js",
    "research-assets:check": "node tools/check-research-assets.js",
    "rankings:generate": "node tools/generate-rankings.js",
    "search:generate": "node tools/generate-search-index.js",
    "article-registry:generate": "node tools/generate-article-registry.js",
    "check:article-pairs": "node tools/check-article-pairs.js --refresh",
    "localize:generate": "node tools/generate-localized-pages.js && node tools/generate-article-registry.js",
    "check:indexing": "node tools/check-indexing-readiness.js",
    "check:social-meta": "node tools/check-social-meta.js",
    "check:editorial": "node tools/check-editorial-quality.js && node tools/check-editorial-schedule.js",
    "editorial:upcoming": "node tools/list-upcoming-publications.js",
    "editorial:schedule": "node tools/check-editorial-schedule.js"
  }
}
