{
  "buildCommand": "node tools/vercel-build.js",
  "outputDirectory": ".",
  "functions": {
    "api/market-data.js": {
      "maxDuration": 10
    },
    "api/live-quotes.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    },
    {
      "source": "/js/clerk-config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
